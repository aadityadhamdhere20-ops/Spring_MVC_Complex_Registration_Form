<%@ page language="java" contentType="text/html; charset=UTF-8"
	pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Registration System</title>

<style>

/* Page background */
body {
	font-family: Arial, sans-serif;
	background: linear-gradient(to right, #4facfe, #00f2fe);
	margin: 0;
	padding: 0;
}

/* Center container */
.container {
	width: 400px;
	margin: 100px auto;
	background: white;
	padding: 30px;
	border-radius: 12px;
	text-align: center;
	box-shadow: 0px 5px 15px rgba(0, 0, 0, 0.2);
}

/* Heading */
h1 {
	color: #333;
	margin-bottom: 25px;
}

/* Buttons */
a {
	display: block;
	text-decoration: none;
	background: #4facfe;
	color: white;
	padding: 12px;
	margin: 10px 0;
	border-radius: 8px;
	font-weight: bold;
	transition: 0.3s;
}

/* Hover effect */
a:hover {
	background: #007bff;
}
</style>

</head>

<body>

	<div class="container">
		<h1>Registration System</h1>

		<a href="register">👉 Click here for Registration</a> <a href="list">📋
			View All Records</a>
	</div>

</body>
</html>